# Invoice SaaS — Environment Variables
# Copy this file to .env and fill in your values. NEVER commit the real .env.

# =============================================
# Database (Supabase in prod, Docker locally)
# =============================================
DATABASE_URL=jdbc:postgresql://localhost:5432/invoice_saas
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# =============================================
# JWT
# =============================================
JWT_SECRET=change-me-to-a-random-256-bit-secret-in-production

# =============================================
# Google OAuth2 (get from Google Cloud Console)
# =============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================
# Brevo SMTP (transactional email)
# =============================================
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# =============================================
# Razorpay (subscription billing)
# =============================================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# =============================================
# CORS (frontend origin)
# =============================================
CORS_ORIGINS=http://localhost:4200

# =============================================
# Spring Profile
# =============================================
SPRING_PROFILES_ACTIVE=dev
